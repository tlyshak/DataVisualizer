<Window
    x:Class="DataVisualizer.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="Signal Monitor"
    Height="650"
    Width="1000"
    WindowStartupLocation="CenterScreen"
    Style="{StaticResource MaterialDesignWindow}"
    Icon="{x:Null}">
    <Grid
        Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition
                Height="Auto" />
            <RowDefinition
                Height="Auto" />
            <RowDefinition
                Height="*" />
            <RowDefinition
                Height="Auto" />
        </Grid.RowDefinitions>
        <materialDesign:Card
            Grid.Row="0"
            Padding="12"
            Margin="0,0,0,12">
            <DockPanel
                LastChildFill="False">
                <StackPanel
                    Orientation="Horizontal"
                    DockPanel.Dock="Left">
                    <TextBlock
                        Text="Signal Monitor"
                        FontSize="18"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"
                        Margin="0,0,16,0" />
                </StackPanel>
                <StackPanel
                    Orientation="Horizontal"
                    DockPanel.Dock="Right">
                    <Button
                        Command="{Binding StartCommand}"
                        Margin="0,0,8,0">
                        <StackPanel
                            Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Kind="Play"
                                Width="18"
                                Height="18"
                                Margin="0,0,6,0" />
                            <TextBlock
                                Text="Start" />
                        </StackPanel>
                    </Button>
                    <Button
                        Command="{Binding StopCommand}"
                        Margin="0,0,8,0">
                        <StackPanel
                            Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Kind="Stop"
                                Width="18"
                                Height="18"
                                Margin="0,0,6,0" />
                            <TextBlock
                                Text="Stop" />
                        </StackPanel>
                    </Button>
                    <Button
                        Command="{Binding ClearCommand}">
                        <StackPanel
                            Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Kind="Broom"
                                Width="18"
                                Height="18"
                                Margin="0,0,6,0" />
                            <TextBlock
                                Text="Clear" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </materialDesign:Card>
        <materialDesign:Card
            Grid.Row="1"
            Padding="12"
            Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel
                    Grid.Column="0"
                    Margin="0,0,12,0">
                    <TextBlock
                        Text="Frequency filter"
                        FontWeight="SemiBold"
                        Margin="0,0,0,6" />
                    <TextBox
                        Text="{Binding FrequencyContains, UpdateSourceTrigger=PropertyChanged}"
                        materialDesign:HintAssist.Hint="Freq contains (e.g. 103.6)"
                        Height="40" />
                </StackPanel>
                <StackPanel
                    Grid.Column="1"
                    Margin="0,0,12,0">
                    <TextBlock
                        Text="Count filter"
                        FontWeight="SemiBold"
                        Margin="0,0,0,6" />
                    <TextBox
                        Text="{Binding MinCount, UpdateSourceTrigger=PropertyChanged}"
                        materialDesign:HintAssist.Hint="Min count (e.g. 10)"
                        Height="40" />
                </StackPanel>
                <StackPanel
                    Grid.Column="2"
                    VerticalAlignment="Bottom">
                    <Button
                        Content="Reset filters"
                        Command="{Binding ResetFiltersCommand}"
                        Margin="0,0,0,2" />
                </StackPanel>
            </Grid>
        </materialDesign:Card>
        <materialDesign:Card
            Grid.Row="2"
            Padding="8">
            <DataGrid
                ItemsSource="{Binding RecordsView}"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                CanUserSortColumns="True"
                HeadersVisibility="Column"
                GridLinesVisibility="Horizontal"
                RowHeaderWidth="0"
                AlternationCount="2"
                materialDesign:DataGridAssist.CellPadding="10,6"
                materialDesign:DataGridAssist.ColumnHeaderPadding="10,8"
                materialDesign:DataGridAssist.EnableEditBoxAssist="False">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Header="Created On"
                        Binding="{Binding CreatedOn}"
                        SortMemberPath="CreatedOn"
                        Width="2*" />
                    <DataGridTextColumn
                        Header="Frequency, MHz"
                        Binding="{Binding MedianFrequency, StringFormat=F3}"
                        SortMemberPath="FrequencyMHz"
                        Width="*" />
                    <DataGridTextColumn
                        Header="Bandwidth, kHz"
                        Binding="{Binding BandwidthKHz, StringFormat=F3}"
                        SortMemberPath="BandwidthKHz"
                        Width="*" />
                    <DataGridTextColumn
                        Header="SNR, dB"
                        Binding="{Binding SnrDb, StringFormat=F3}"
                        SortMemberPath="SnrDb"
                        Width="*" />
                    <DataGridTextColumn
                        Header="Count"
                        Binding="{Binding Count}"
                        SortMemberPath="Count"
                        Width="Auto" />
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
        <Border
            Grid.Row="3"
            Margin="0,8,0,0"
            Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    Text="{Binding StatusText}"
                    Opacity="0.8" />
                <TextBlock
                    Grid.Column="1"
                    Text="{Binding RecordsSummary}"
                    Opacity="0.8" />
            </Grid>
        </Border>
    </Grid>
</Window>